#!/bin/bash
photos(){
    cd ~/Pictures/
    rclone sync . "drive:Personal/Pictures"
    cd -
}

config(){
    cd ~/.code/
    git add .
    git commit -m "+"
    git push origin main
    cd -
}

all(){
    photos
    config
}

case $1 in 
    -p)
        photos;;
    -c)
        config;;
    *)
        all;;
esac
