#!/bin/bash
bg=$(cat ~/.cache/wal/colors | sed -n '11p')
dir=$(find "$HOME/media/Torrent/" -type d -not -path "*/Course/*" | sort | dmenu -nb "#0f0f0f" -sb $bg -i -l 30 -p "Choose :")

if [ $1 == "-d" ];then
    mpv "$dir"
else
    vid(){
        [ $dir ] && file=$(ls "$dir" | dmenu -nb "#0f0f0f" -sb $bg -i -l 30 -p "Play :" )
        fullpath="$dir/$file"
        [ -f "$fullpath" ] && mpv "$fullpath"
    }
    vid 
    while [ -f "$fullpath" ];do
        vid
    done
fi
